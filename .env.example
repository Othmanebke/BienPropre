# ============================================================
# BienPropre — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ---- Supabase -----------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Stripe (public key — safe to expose in browser) --------
# Found in: Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx

# ---- Stripe Webhook (server-side only — NEVER prefix with VITE_) -----
# Used in the Supabase Edge Function / backend only.
# Set this via: supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ---- Stripe Price / Product IDs (optional shortcut) ---------
# If you use Stripe-hosted prices instead of dynamic line items:
# VITE_STRIPE_BASE_PRICE_ID=price_xxxxxxxxxxxxxxxx

# ---- App -----------------------------------------------
VITE_APP_URL=http://localhost:5173
